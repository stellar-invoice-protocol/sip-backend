# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sip_backend_db

# Soroban/Stellar
SOROBAN_RPC_URL=https://rpc-futurenet.stellar.org:443
CONTRACT_ID=CAQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Disable services (for testing)
DISABLE_INDEXER=false
DISABLE_NOTIFICATIONS=false

# Email
EMAIL_TRANSPORT=console
EMAIL_FROM=noreply@stellar-invoices.app
# For SMTP transport:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
